---
import PageLayout from '@layouts/PageLayout.astro';
import Search from '@components/global/Search.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Search', url: '/search' }
];
---

<PageLayout 
  title="Search" 
  description="Search for articles, guides, and tutorials across our platform."
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-3xl mx-auto text-center py-12">
    <div class="glass-card p-8 md:p-12 rounded-3xl mb-8 border border-[var(--color-primary-500)]/30 shadow-[0_0_40px_rgba(var(--color-primary-500),0.1)]">
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-6">What are you looking for?</h2>
      
      <!-- Trigger button that acts like an input visually to open the search modal -->
      <button 
        id="search-page-trigger"
        class="w-full flex items-center px-6 py-4 rounded-xl bg-[var(--bg-tertiary)] border border-[var(--border-color)] text-left hover:border-[var(--color-primary-500)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary-500)] transition-all group"
      >
        <svg class="w-6 h-6 text-[var(--text-muted)] group-hover:text-[var(--color-primary-500)] mr-4 transition-colors" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span class="text-lg text-[var(--text-muted)] flex-grow">Search posts...</span>
        <kbd class="hidden sm:inline-block font-sans text-xs font-semibold px-2 py-1 rounded bg-[var(--bg-primary)] border border-[var(--border-color)] text-[var(--text-secondary)]">Cmd + K</kbd>
      </button>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
      <div class="glass-card p-6 rounded-2xl">
        <h3 class="font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-[var(--color-accent-500)]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Trending Searches
        </h3>
        <ul class="space-y-3">
          <li><button class="trending-search text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Astro Framework</button></li>
          <li><button class="trending-search text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Tailwind CSS v4</button></li>
          <li><button class="trending-search text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Decap CMS Setup</button></li>
          <li><button class="trending-search text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Cloudflare Pages</button></li>
        </ul>
      </div>
      
      <div class="glass-card p-6 rounded-2xl">
        <h3 class="font-bold text-[var(--text-primary)] mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-[var(--color-primary-500)]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Browse by Category
        </h3>
        <ul class="space-y-3">
          <li><a href="/categories/technology" class="text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Technology</a></li>
          <li><a href="/categories/design" class="text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Design</a></li>
          <li><a href="/categories/development" class="text-[var(--text-secondary)] hover:text-[var(--color-primary-500)] transition-colors">Development</a></li>
          <li><a href="/categories" class="text-[var(--color-primary-500)] font-medium hover:underline">View All Categories &rarr;</a></li>
        </ul>
      </div>
    </div>
  </div>

  <script>
    // Link the page trigger to the global search modal
    const triggerBtn = document.getElementById('search-page-trigger');
    const headerSearchBtn = document.getElementById('search-btn');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    
    triggerBtn?.addEventListener('click', () => {
      headerSearchBtn?.click();
    });

    // Handle trending search clicks
    document.querySelectorAll('.trending-search').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const text = (e.target as HTMLElement).textContent;
        headerSearchBtn?.click();
        
        // Wait for modal to open then set value and trigger search
        setTimeout(() => {
          if (searchInput) {
            searchInput.value = text || '';
            searchInput.dispatchEvent(new Event('input'));
          }
        }, 150);
      });
    });

    // Support for ?q= query parameter
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('q');
    if (query) {
      setTimeout(() => {
        headerSearchBtn?.click();
        setTimeout(() => {
          if (searchInput) {
            searchInput.value = query;
            searchInput.dispatchEvent(new Event('input'));
          }
        }, 150);
      }, 500); // Wait for page load
    }
  </script>
</PageLayout>
