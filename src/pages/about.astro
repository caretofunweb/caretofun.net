---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import AuthorBox from '@components/blog/AuthorBox.astro';

const allAuthors = await getCollection('authors');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'About', url: '/about' }
];
---

<PageLayout 
  title="About AstroBlog" 
  description="Learn about our mission, our team, and the technology behind this platform."
  breadcrumbs={breadcrumbs}
>
  <div class="space-y-24 pb-16">
    
    <!-- Mission Section -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-[var(--text-primary)]">Our Mission</h2>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed">
          We believe that publishing content on the web should be fast, beautiful, and accessible. Our mission is to provide creators with a platform that gets out of their way and lets their words shine.
        </p>
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed">
          By combining the raw speed of static site generation with the convenience of a modern CMS, we've created a blogging experience that both writers and readers will love.
        </p>
      </div>
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-primary-500)] to-[var(--color-accent-500)] rounded-3xl blur-2xl opacity-20 dark:opacity-40 animate-pulse-slow"></div>
        <div class="relative glass-card p-8 rounded-3xl border border-[var(--border-color)]">
          <ul class="space-y-4">
            <li class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-[var(--color-primary-500)]/10 flex items-center justify-center text-[var(--color-primary-500)] shrink-0">
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-[var(--text-primary)]">Lightning Fast</h4>
                <p class="text-sm text-[var(--text-muted)]">Zero JavaScript by default for maximum performance.</p>
              </div>
            </li>
            <li class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-[var(--color-primary-500)]/10 flex items-center justify-center text-[var(--color-primary-500)] shrink-0">
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-[var(--text-primary)]">Secure & SEO Ready</h4>
                <p class="text-sm text-[var(--text-muted)]">Built-in best practices for search engines and security.</p>
              </div>
            </li>
            <li class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-[var(--color-primary-500)]/10 flex items-center justify-center text-[var(--color-primary-500)] shrink-0">
                <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </div>
              <div>
                <h4 class="font-bold text-[var(--text-primary)]">Easy to Edit</h4>
                <p class="text-sm text-[var(--text-muted)]">Powerful CMS dashboard for content management.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="text-center">
      <h2 class="text-3xl font-bold text-[var(--text-primary)] mb-8">Built With</h2>
      <div class="flex flex-wrap justify-center gap-6">
        <div class="glass-card px-6 py-4 rounded-xl flex items-center gap-3">
          <span class="font-bold text-[var(--text-primary)]">Astro</span>
        </div>
        <div class="glass-card px-6 py-4 rounded-xl flex items-center gap-3">
          <span class="font-bold text-[var(--text-primary)]">Tailwind CSS</span>
        </div>
        <div class="glass-card px-6 py-4 rounded-xl flex items-center gap-3">
          <span class="font-bold text-[var(--text-primary)]">Decap CMS</span>
        </div>
        <div class="glass-card px-6 py-4 rounded-xl flex items-center gap-3">
          <span class="font-bold text-[var(--text-primary)]">Cloudflare Pages</span>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section>
      <h2 class="text-3xl font-bold text-[var(--text-primary)] mb-10 text-center">Our Team</h2>
      <div class="grid grid-cols-1 gap-8 max-w-3xl mx-auto">
        {allAuthors.map(author => (
          <AuthorBox author={author} />
        ))}
      </div>
    </section>

  </div>
</PageLayout>
