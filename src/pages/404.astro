---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout title="404: Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex-grow flex flex-col items-center justify-center min-h-[70vh] relative overflow-hidden px-4 text-center">
    
    <!-- Decorative background elements -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[80vw] max-w-[600px] h-[80vw] max-h-[600px] bg-gradient-to-tr from-[var(--color-primary-500)] to-[var(--color-accent-500)] rounded-full blur-[100px] opacity-[0.05] dark:opacity-[0.1] z-0"></div>

    <div class="relative z-10 animate-fade-up">
      <h1 class="text-9xl md:text-[12rem] font-black leading-none bg-clip-text text-transparent bg-gradient-to-b from-[var(--color-primary-500)] to-[var(--color-accent-500)] opacity-80 mb-4 select-none">
        404
      </h1>
      
      <h2 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-6">
        Oops! Page not found
      </h2>
      
      <p class="text-lg text-[var(--text-secondary)] max-w-md mx-auto mb-10">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/" variant="primary" size="lg" class="rounded-full px-8">
          Go back home
        </Button>
        <Button href="/search" variant="secondary" size="lg" class="rounded-full px-8">
          Search site
        </Button>
      </div>
    </div>
    
    <!-- Floating elements for playfulness -->
    <div class="absolute w-12 h-12 rounded-xl bg-[var(--color-primary-500)] opacity-20 rotate-12 animate-float left-1/4 top-1/3 hidden md:block"></div>
    <div class="absolute w-8 h-8 rounded-full bg-[var(--color-accent-500)] opacity-20 animate-float right-1/4 top-1/2 hidden md:block" style="animation-delay: -2s;"></div>
  </div>
</BaseLayout>
