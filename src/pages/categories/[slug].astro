---
import { getCollection, getEntry } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import PostGrid from '@components/blog/PostGrid.astro';

export async function getStaticPaths() {
  const allCategories = await getCollection('categories');
  const allPosts = await getCollection('posts');
  
  const now = new Date();
  const validPosts = allPosts
    .filter(post => !post.data.draft && post.data.date <= now)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return allCategories.map(category => {
    const slug = category.data?.slug || category.id;
    const categoryPosts = validPosts.filter(post => post.data.category === slug);
    return {
      params: { slug: slug },
      props: { category, posts: categoryPosts },
    };
  });
}

const { category, posts } = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Categories', url: '/categories' },
  { name: category.data.title, url: `/categories/${category.slug}` }
];
---

<PageLayout 
  title={category.data.title} 
  description={category.data.description}
  breadcrumbs={breadcrumbs}
>
  <div class="mb-12 p-6 md:p-8 rounded-2xl glass-card border border-[var(--border-color)] relative overflow-hidden flex items-center justify-between">
    <div class="absolute inset-0 opacity-10" style={`background: linear-gradient(135deg, ${category.data.color}, transparent);`}></div>
    
    <div class="relative z-10">
      <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-2">About {category.data.title}</h2>
      <p class="text-[var(--text-secondary)]">{posts.length} {posts.length === 1 ? 'article' : 'articles'} in this category</p>
    </div>
    
    <div 
      class="relative z-10 w-16 h-16 rounded-full flex items-center justify-center shadow-lg"
      style={`background-color: ${category.data.color}; color: white;`}
    >
      <svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
      </svg>
    </div>
  </div>

  {posts.length > 0 ? (
    <PostGrid posts={posts} />
  ) : (
    <div class="text-center py-20 text-[var(--text-muted)]">
      <svg class="w-16 h-16 mx-auto mb-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p class="text-xl">No posts found in this category.</p>
    </div>
  )}
</PageLayout>
