---
import { getCollection } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  
  // Exclude drafts and future posts from generation
  const now = new Date();
  const validPosts = allPosts.filter(post => !post.data.draft && post.data.date <= now);
  
  const paths = [];
  
  for (const post of validPosts) {
    const baseSlug = post.data?.slug || post.id;
    
    // Split the raw markdown body by the WordPress nextpage tag
    const pages = post.body ? post.body.split('<!--nextpage-->') : [''];
    
    pages.forEach((pageContent, index) => {
      const pageNum = index + 1;
      // Page 1 is the root slug, subsequent pages are slug/2, slug/3, etc.
      const currentSlug = pageNum === 1 ? baseSlug : `${baseSlug}/${pageNum}`;
      
      paths.push({
        params: { slug: currentSlug },
        props: { 
          post, 
          pageContent, 
          currentPage: pageNum, 
          totalPages: pages.length,
          baseSlug 
        },
      });
    });
  }
  
  return paths;
}

const { post, pageContent, currentPage, totalPages, baseSlug } = Astro.props;

// Extract headings from the raw markdown page content for the Table of Contents
const headings = [];
const headingRegex = /^(#{1,6})\s+(.+)$/gm;
let match;
while ((match = headingRegex.exec(pageContent)) !== null) {
  headings.push({
    depth: match[1].length,
    slug: match[2].toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, ''),
    text: match[2]
  });
}

// Convert Markdown chunk to HTML
const htmlContent = marked.parse(pageContent || '');
---

<PostLayout post={post} headings={headings}>
  <div class="prose prose-lg dark:prose-invert max-w-none prose-img:rounded-xl prose-img:shadow-lg prose-a:text-primary hover:prose-a:text-primary/80" set:html={htmlContent} />
  
  {totalPages > 1 && (
    <div class="mt-16 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4 bg-muted/20 p-6 rounded-2xl shadow-sm">
      {currentPage > 1 ? (
        <a 
          href={`/blog/${currentPage === 2 ? baseSlug : `${baseSlug}/${currentPage - 1}`}`} 
          class="flex items-center gap-2 px-6 py-3 bg-background border border-border rounded-xl text-foreground font-semibold hover:bg-muted hover:border-primary/50 transition-all shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Previous Chapter
        </a>
      ) : (
        <span class="flex items-center gap-2 px-6 py-3 border border-border/50 rounded-xl text-muted-foreground/50 font-semibold cursor-not-allowed">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Previous Chapter
        </span>
      )}
      
      <div class="flex flex-col items-center">
        <span class="text-xs font-bold uppercase tracking-wider text-muted-foreground mb-1">Novel Progress</span>
        <span class="text-sm font-semibold bg-primary/10 text-primary px-4 py-1.5 rounded-full border border-primary/20">
          Page {currentPage} of {totalPages}
        </span>
      </div>
      
      {currentPage < totalPages ? (
        <a 
          href={`/blog/${baseSlug}/${currentPage + 1}`} 
          class="flex items-center gap-2 px-6 py-3 bg-primary text-primary-foreground border border-primary rounded-xl font-semibold hover:bg-primary/90 transition-all shadow-md hover:shadow-lg"
        >
          Next Chapter
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      ) : (
        <span class="flex items-center gap-2 px-6 py-3 border border-border/50 rounded-xl text-muted-foreground/50 font-semibold cursor-not-allowed">
          Next Chapter
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </span>
      )}
    </div>
  )}
</PostLayout>
