---
import { getCollection } from 'astro:content';
import PostGrid from '@components/blog/PostGrid.astro';

const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

if (latestPosts.length === 0) {
  return null;
}
---

<section>
  <div class="border-b-2 border-black mb-6 flex justify-between items-end">
    <h2 class="bg-[var(--color-primary-500)] text-white text-sm font-bold uppercase tracking-wider px-4 py-2 inline-block">
      Latest News
    </h2>
    <a href="/blog" class="text-xs font-bold uppercase text-gray-500 hover:text-[var(--color-primary-500)] mb-2 flex items-center">
      View All <svg class="w-3 h-3 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    </a>
  </div>

  <PostGrid posts={latestPosts} />
</section>
