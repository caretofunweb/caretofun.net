---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const popularPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 5);

if (popularPosts.length === 0) {
  return null;
}
---

<section class="bg-white border border-[var(--border-color)]">
  <div class="bg-[var(--color-primary-500)] text-white px-4 py-2 font-bold uppercase tracking-wider text-sm">
    Popular Posts
  </div>

  <div class="p-5 space-y-5">
    {popularPosts.map((post, index) => (
      <a href={`/blog/${post.data?.slug || post.id}`} class="group flex gap-4 items-start border-b border-[var(--border-color)] pb-5 last:border-0 last:pb-0">
        <div class="text-3xl font-black text-gray-200 group-hover:text-[var(--color-primary-500)] transition-colors min-w-[32px] text-center">
          {index + 1}
        </div>
        <div>
          <h3 class="font-bold text-black group-hover:text-[var(--color-primary-500)] transition-colors leading-snug line-clamp-2 mb-1">
            {post.data.title}
          </h3>
          <div class="flex items-center gap-2 text-[10px] uppercase font-bold text-gray-500">
            <span class="text-[var(--color-primary-500)]">
              {post.data.category}
            </span>
            <span>/</span>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
