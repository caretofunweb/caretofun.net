---
export interface Props {
  author: {
    data: {
      name: string;
      avatar?: string;
      bio: string;
      social?: {
        twitter?: string;
        github?: string;
        linkedin?: string;
        website?: string;
      };
    };
  };
}

const { author } = Astro.props;
const { name, avatar, bio, social } = author.data;
---

<div class="glass-card p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start border-l-4 border-l-[var(--color-primary-500)]">
  {avatar ? (
    <img src={avatar} alt={name} class="w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover shrink-0 border-2 border-[var(--bg-primary)] shadow-md" />
  ) : (
    <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full shrink-0 bg-gradient-to-br from-[var(--color-primary-500)] to-[var(--color-accent-500)] flex items-center justify-center text-white text-2xl font-bold shadow-md">
      {name.charAt(0)}
    </div>
  )}
  
  <div class="flex-grow">
    <h4 class="text-xl font-bold text-[var(--text-primary)] mb-2">{name}</h4>
    <p class="text-[var(--text-secondary)] mb-4 leading-relaxed text-sm sm:text-base">
      {bio}
    </p>
    
    {social && (
      <div class="flex items-center gap-3">
        {social.twitter && (
          <a href={social.twitter} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--color-primary-500)] transition-colors p-2 rounded-full hover:bg-[var(--bg-tertiary)]" aria-label="Twitter">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
          </a>
        )}
        {social.github && (
          <a href={social.github} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--color-primary-500)] transition-colors p-2 rounded-full hover:bg-[var(--bg-tertiary)]" aria-label="GitHub">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        )}
        {social.linkedin && (
          <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--color-primary-500)] transition-colors p-2 rounded-full hover:bg-[var(--bg-tertiary)]" aria-label="LinkedIn">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        )}
        {social.website && (
          <a href={social.website} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-[var(--color-primary-500)] transition-colors p-2 rounded-full hover:bg-[var(--bg-tertiary)]" aria-label="Website">
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </a>
        )}
      </div>
    )}
  </div>
</div>
