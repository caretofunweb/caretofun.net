---
import { getReadingTime } from '@utils/readingTime';
import CategoryBadge from './CategoryBadge.astro';

export interface Props {
  post: {
    id: string;
    slug?: string;
    data: {
      title: string;
      description: string;
      image?: string;
      imageAlt?: string;
      category: string;
      date: Date;
    };
    body?: string;
  };
}

const { post } = Astro.props;
const { title, description, image, imageAlt, category, date } = post.data;
const slug = post.data?.slug || post.id;
const readingTime = getReadingTime(post.body || '');

// Fallback gradient if no image
const fallbackGradient = 'bg-gradient-to-br from-[var(--color-primary-500)] to-[var(--color-accent-500)]';
---

<a href={`/blog/${slug}`} class="group block h-full">
  <article class="flex flex-col h-full bg-white border border-[var(--border-color)] group-hover:border-black transition-colors">
    <!-- Image Area -->
    <div class="relative aspect-[16/10] overflow-hidden bg-gray-100 shrink-0">
      {image ? (
        <img 
          src={image} 
          alt={imageAlt || title} 
          loading="lazy"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 grayscale-[20%] group-hover:grayscale-0" 
        />
      ) : (
        <div class={`w-full h-full bg-gray-200 flex items-center justify-center`}>
          <svg class="w-12 h-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      )}
      
      <!-- Category Badge Overlay -->
      <div class="absolute top-0 left-0 z-10">
        <span class="bg-[var(--color-primary-500)] text-white text-[10px] font-bold uppercase tracking-wider px-2 py-1">
          {category}
        </span>
      </div>
    </div>
    
    <!-- Content Area -->
    <div class="p-5 flex flex-col flex-grow">
      <h3 class="text-xl font-bold text-black mb-2 group-hover:text-[var(--color-primary-500)] transition-colors line-clamp-2 leading-tight">
        {title}
      </h3>
      
      <div class="flex items-center gap-2 text-[11px] font-bold text-gray-500 uppercase tracking-wider mb-3">
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </time>
        <span>/</span>
        <span>{readingTime}</span>
      </div>

      <p class="text-gray-600 text-sm mb-0 line-clamp-3 flex-grow">
        {description}
      </p>
    </div>
  </article>
</a>
