---
import { getReadingTime } from '@utils/readingTime';

export interface Props {
  post: {
    id: string;
    slug?: string;
    data: {
      title: string;
      description: string;
      image?: string;
      imageAlt?: string;
      category: string;
      date: Date;
      author?: string;
    };
    body?: string;
  };
  large?: boolean;
}

const { post, large = true } = Astro.props;
const { title, description, image, imageAlt, category, date, author } = post.data;
const slug = post.data?.slug || post.id;

const fallbackGradient = 'bg-gray-800';
---

<a href={`/blog/${slug}`} class="group block relative overflow-hidden h-full w-full bg-black">
  <!-- Background Image -->
  {image ? (
    <img 
      src={image} 
      alt={imageAlt || title} 
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100" 
    />
  ) : (
    <div class={`absolute inset-0 w-full h-full ${fallbackGradient}`}></div>
  )}

  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/50 to-transparent"></div>

  <!-- Category Badge -->
  <div class="absolute top-4 left-4 z-10">
    <span class="bg-[var(--color-primary-500)] text-white text-xs font-bold uppercase tracking-wider px-2 py-1">
      {category}
    </span>
  </div>

  <!-- Content -->
  <div class="absolute inset-0 p-6 flex flex-col justify-end">
    <h3 class={`font-bold text-white mb-2 leading-tight ${large ? 'text-3xl md:text-4xl' : 'text-xl md:text-2xl'}`}>
      {title}
    </h3>
    
    {large && (
      <p class="text-gray-300 text-sm md:text-base mb-4 line-clamp-2 max-w-2xl">
        {description}
      </p>
    )}
    
    <div class="flex items-center gap-3 text-xs font-bold text-gray-400 uppercase tracking-wide">
      <span class="text-white">
        {author || 'Admin'}
      </span>
      <span>/</span>
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </time>
    </div>
  </div>
</a>
