---
import '@styles/global.css';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';
import AdSense from '@components/global/AdSense.astro';
import { getWebsiteSchema, getOpenGraphMeta, getTwitterMeta } from '@utils/seo';
import settings from '@data/settings.json';
import adsenseData from '@data/adsense.json';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonicalUrl?: string;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

const {
  title = settings.title,
  description = settings.description,
  image = settings.seo.ogImage,
  type = 'website',
  canonicalUrl = Astro.url.href,
  publishedTime,
  modifiedTime,
  author,
  section,
  tags = [],
} = Astro.props;

const siteTitle = title === settings.title ? title : `${title} | ${settings.title}`;
const ogMeta = getOpenGraphMeta({ title: siteTitle, description, url: canonicalUrl, image, type, publishedTime, modifiedTime, author, section, tags });
const twitterMeta = getTwitterMeta({ title: siteTitle, description, url: canonicalUrl, image });
const schema = getWebsiteSchema(settings.siteUrl);
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${settings.title} RSS Feed`} href={new URL('rss.xml', Astro.site)} />

    <!-- Open Graph -->
    {Object.entries(ogMeta).map(([property, content]) => (
      <meta property={property} content={content} />
    ))}

    <!-- Twitter -->
    {Object.entries(twitterMeta).map(([name, content]) => (
      <meta name={name} content={content} />
    ))}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Theme Initialization Script -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
    </script>
    
    <!-- Google AdSense Global Script -->
    {adsenseData.enabled && adsenseData.clientId && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseData.clientId}`} crossorigin="anonymous"></script>
    )}
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)] antialiased min-h-screen flex flex-col relative overflow-x-hidden">
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    
    <!-- Boxed Layout Wrapper -->
    <div class="max-w-[1200px] mx-auto w-full bg-[var(--bg-secondary)] shadow-2xl flex flex-col min-h-screen relative border-x border-[var(--border-color)]">
      <Header />
      
      <!-- Header AdSense Placement -->
      {adsenseData.enabled && adsenseData.headerSlotId && (
        <div class="border-b border-[var(--border-color)] bg-[var(--bg-primary)] px-4">
          <div class="max-w-4xl mx-auto py-4">
            <AdSense slotId={adsenseData.headerSlotId} className="w-full h-[90px]" />
          </div>
        </div>
      )}

      <main id="main-content" class="flex-grow flex flex-col">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
